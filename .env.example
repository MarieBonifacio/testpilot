# TestPilot — Variables d'environnement
# Copie ce fichier en .env et remplis ta clé
# Lance ensuite : node proxy.js

ANTHROPIC_API_KEY=sk-ant-api03-REMPLACE_PAR_TA_CLE
PORT=3000

# CORS — liste d'origines autorisées séparées par des virgules
# Laisser vide (ou ne pas définir) pour autoriser toutes les origines (*) — dev only
# Exemple prod : CORS_ORIGINS=https://testpilot.example.com,https://app.example.com
CORS_ORIGINS=
