{
  "name": "testpilot",
  "version": "2.0.0",
  "description": "Générateur de scénarios de tests assisté par IA — avec persistance multi-projets et bibliothèque TNR.",
  "main": "proxy.js",
  "scripts": {
    "start": "node proxy.js",
    "init-db": "node init_db.js",
    "dev": "node init_db.js && node proxy.js",
    "test": "jest tests/ --forceExit",
    "test:watch": "jest tests/ --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarieBonifacio/testpilot.git"
  },
  "keywords": [
    "testing",
    "qa",
    "test-automation",
    "ai",
    "gherkin"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MarieBonifacio/testpilot/issues"
  },
  "homepage": "https://github.com/MarieBonifacio/testpilot#readme",
  "dependencies": {
    "docx": "^9.6.1",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
